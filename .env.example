# Copy to .env and fill in. Never commit .env.

# Which provider runs the agent nodes: anthropic | openai | google
LLM_PROVIDER=anthropic

# Only the selected provider's key is required.
ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# REQUIRED regardless of LLM_PROVIDER.
# The ATS scorer uses OpenAI embeddings for semantic keyword matching, because
# Anthropic has no embeddings API and a local model is too heavy for
# Streamlit Cloud. If LLM_PROVIDER=openai this is the same key as above.
OPENAI_API_KEY=

# Optional model overrides.
# ANTHROPIC_MODEL=claude-opus-4-8
# OPENAI_MODEL=gpt-4o
# GOOGLE_MODEL=gemini-2.0-flash
# EMBEDDING_MODEL=text-embedding-3-small

# Where the base resume is persisted.
# DATA_DIR=./data
